<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MouseToPad</RootNamespace>
    <AssemblyName>MouseToPad</AssemblyName>
    <!-- Regenerate with scripts\make-icon.ps1 if the glyph changes. -->
    <ApplicationIcon>app.ico</ApplicationIcon>
    <Version>1.7.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <!-- WPF has no built-in tray icon; this is the de-facto standard one. -->
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="2.0.1" />
    <PackageReference Include="Nefarius.ViGEm.Client" Version="1.21.256" />
    <!-- GDI+ used to draw the tray icon at runtime. -->
    <PackageReference Include="System.Drawing.Common" Version="8.0.10" />
  </ItemGroup>

</Project>
