<?xml version="1.0" encoding="utf-8"?>
<!-- Use only nuget.org for this project: the machine-wide Telerik feed
     requires credentials and breaks restore with a 401. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
